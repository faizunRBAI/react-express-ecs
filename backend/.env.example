# Backend environment variables (copy to .env for local development)
NODE_ENV=development
PORT=3000

# Database (local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=appdb
DB_USER=appuser
DB_PASSWORD=localdevpassword
DB_SSL=false

# CORS — comma-separated list of allowed origins, or * for all
ALLOWED_ORIGINS=http://localhost:5173
